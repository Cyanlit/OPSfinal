# ── OCR Core Service ────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
EASYOCR_MODEL_STORAGE=./models

# ── Desktop GUI Client ──────────────────────────────────────────────────────
# URL of the running OCR service. Defaults to http://127.0.0.1:8000
OCR_SERVICE_URL=http://127.0.0.1:8000
# Confidence threshold passed to /api/v1/scan (0.0–1.0, default 0.5)
MIN_CONFIDENCE=0.5

# ── LINE Bot (not in scope for this split, kept for reference) ─────────────
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
